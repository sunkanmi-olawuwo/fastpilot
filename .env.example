# ============================================================
# FastPilot — environment configuration
# Copy to .env (repo root) and fill in:  cp .env.example .env
# On Railway these are set per-service; os.environ wins over .env.
# ============================================================

# --- Qdrant Cloud (vector DB) — https://cloud.qdrant.io ---
# Port 443 is the safest default on restricted networks; 6333 if your network allows it.
QDRANT_URL=https://your-cluster-url.cloud.qdrant.io:443
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION=rag_accelerator_capstone_final

# --- Voyage AI (embeddings + reranker) — https://dash.voyageai.com ---
VOYAGE_API_KEY=your_voyage_api_key_here

# --- Google Gemini (generation) — https://aistudio.google.com/apikey ---
GOOGLE_API_KEY=your_google_api_key_here
LLM_MODEL=gemini-2.5-flash

# --- Redis Cloud (conversation memory + semantic cache) — https://redis.io/cloud ---
# Needs a free DB with the "Search & Query" capability (HNSW: FT.CREATE/FT.SEARCH).
REDIS_HOST=your-db.cloud.redislabs.com
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_USERNAME=default
REDIS_SSL=true

# Semantic cache + conversation memory tuning
CACHE_DISTANCE_THRESHOLD=0.16   # calibrated; favours zero wrong-answer serving over hit-rate
CACHE_TTL=86400
CONVERSATION_WINDOW_SIZE=10
CONVERSATION_SESSION_TTL=86400

# --- Opik observability (free via Comet) — https://www.comet.com → Opik ---
OPIK_API_KEY=your_opik_api_key_here
OPIK_WORKSPACE=default
OPIK_PROJECT_NAME=fastpilot

# --- App ---
# Comma-separated allowed CORS origins (narrow to the frontend origin in prod).
CORS_ORIGINS=*
# Playground kill switch — set false to hide the mode and 404 /execute.
PLAYGROUND_ENABLED=true
# Frontend → backend URL (default for local dev; on Railway use the internal URL).
API_BASE_URL=http://localhost:8000
